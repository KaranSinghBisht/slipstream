# Copy to .env and fill in. NEVER commit .env

# Solana base layer (devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# MagicBlock Magic Router (devnet) — routes to ER or base automatically
MAGIC_ROUTER_URL=https://devnet-router.magicblock.app
ER_RPC_URL=https://devnet.magicblock.app

# Flash Trade V2 (mainnet, open reads)
FLASH_API_URL=https://flashapi.trade
# V2_RPC_URL=  # trade-submission RPC, from Flash docs/Telegram

# Burner wallet path for devnet ops — NEVER the main wallet
WALLET_KEYPAIR_PATH=./keypairs/burner-devnet.json

# Claude API for the scout agent (optional — without it the deterministic ranker runs)
ANTHROPIC_API_KEY=
# Scout tries SCOUT_MODEL first, then SCOUT_FALLBACK_MODEL (Fable 5 is sometimes gated).
# SCOUT_MODEL=claude-fable-5
# SCOUT_FALLBACK_MODEL=claude-sonnet-4-6

# Mainnet RPC for Flash leader indexing (read-only; public endpoint works but rate-limits)
MAINNET_RPC_URL=https://api.mainnet-beta.solana.com

# Unified API server port (the web app defaults to http://localhost:8787)
API_PORT=8787
# In web/, set NEXT_PUBLIC_API_BASE to point the UI at a non-default API host.
# In web/, NEXT_PUBLIC_SOLANA_RPC sets the wallet-adapter cluster (defaults to devnet).
