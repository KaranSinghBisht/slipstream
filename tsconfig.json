{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": [
    "tests/**/*.ts",
    "indexer/**/*.ts",
    "server/**/*.ts",
    "agent/**/*.ts",
    "bridge/**/*.ts"
  ],
  "exclude": ["node_modules", "web", "dist"]
}
